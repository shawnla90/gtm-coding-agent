# HubSpot Landing Engine — environment template
# Copy this to .env and fill in your values. .env is gitignored.

# ---- HubSpot ---------------------------------------------------------------
# Create a private app at: Settings → Integrations → Private Apps
# Required scope: "content"
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-replace-me

# Path to the HubL template in your portal's Design Manager.
# Default points at the bundled hubspot-template/landing-page.html once you
# upload it via the HubSpot CLI (see hubspot-template/README.md).
HUBSPOT_TEMPLATE_PATH=/landing-engine/landing-page.html

# Optional: set this if you want briefs to be sourced from HubSpot CMS Blog
# Posts (category = "Brief") instead of local files. Default is "local".
BRIEF_SOURCE=local

# ---- Claude / Anthropic ---------------------------------------------------
# Path A (default): leave blank. Pipeline shells out to `claude` CLI subprocess
# and inherits your Claude.com session. See README → "Required model access".
#
# Path B (BYOK): set this and pass --use-sdk to the pipeline. The pipeline will
# route through the official anthropic SDK instead.
ANTHROPIC_API_KEY=

# ---- Exa (optional, for company research) ----------------------------------
# Used by the `research` step. Free tier gives ~1000 calls/month.
# Get a key at https://exa.ai
EXA_API_KEY=

# ---- Output controls ------------------------------------------------------
# Default page state when publishing. DRAFT is safe. PUBLISHED_OR_SCHEDULED
# pushes the page live immediately. The pipeline only honors the override if
# you also pass --state on the CLI; this is the "max allowed" cap.
HUBSPOT_PAGE_STATE_CAP=DRAFT

# Where SQLite cache lives. Stable across runs; delete to force re-enrich.
CACHE_DB=cache.db
