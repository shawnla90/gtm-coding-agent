# HubSpot private-app token
# Settings → Integrations → Private Apps → Create → scope: crm.objects.deals read/write,
# crm.objects.contacts.read, crm.objects.companies.read
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Apollo API key
# apollo.io → Settings → API → generate key
APOLLO_API_KEY=your_apollo_api_key_here

# Exa news-search key (optional — script runs without it, news check is skipped)
# exa.ai → dashboard → keys
EXA_API_KEY=
