# Copy to .env.local and fill in real values. Never commit .env.local.

# Apify CLI should also be authenticated separately: `apify login`
APIFY_TOKEN=

# Claude Opus 4.6 for signal extraction in analyze_content.py
ANTHROPIC_API_KEY=

# Basic-auth gate for the deployed preview (proxy.ts)
# Leave blank to disable auth in local dev.
AUTH_USER=
AUTH_PASS=

# Set to 1 to allow local admin mutations via the sources page / API routes.
# Unset in production — the DB is readonly on Vercel.
INTEL_DB_WRITABLE=
